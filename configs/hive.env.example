# Copy to hive.env if you want overrides (hive.env is gitignored).
#   cp configs/hive.env.example configs/hive.env
#
# hive-sample-smoke.sh does not require HIVE_JDBC_URL: Beeline picks the URL from
# hive-site.xml when unset. Uncomment below only if you need an explicit JDBC URL.

# HIVE_JDBC_URL=jdbc:hive2://rl8j11p3-22.acceldata.ce:2181,rl8j11p3-23.acceldata.ce:2181,rl8j11p3-24.acceldata.ce:2181/default;principal=hive/_HOST@ADSRE.COM;serviceDiscoveryMode=zooKeeper;zooKeeperNamespace=hiveserver2

# HIVE_KEYTAB=/etc/security/keytabs/hive.service.keytab
# Optional: by default hive-sample-smoke.sh ignores HIVE_PRINCIPAL_HOST from this
# file and uses the current host FQDN to avoid cross-host principal mismatch.
# To use a pinned host from this file, set HIVE_USE_CONFIG_PRINCIPAL_HOST=1.
# HIVE_PRINCIPAL_HOST=rl8j11p3-24.acceldata.ce
# HIVE_USE_CONFIG_PRINCIPAL_HOST=1
