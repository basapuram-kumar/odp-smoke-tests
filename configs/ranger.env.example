# Copy to ranger.env (gitignored) and set a real password.
#   cp configs/ranger.env.example configs/ranger.env
#
RANGER_USER=admin
RANGER_PASSWORD=REPLACE_ME

# Optional: skip Ambari discovery
# RANGER_BASE_URL=http://ranger-admin-host:6080

# Optional defaults for ./ranger-yarn-all-queue-users-add.sh
# RANGER_YARN_SERVICE_NAME=ub20j11p3_yarn
# RANGER_ADD_USERS=registry,flink
