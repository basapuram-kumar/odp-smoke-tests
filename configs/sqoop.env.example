# Copy to sqoop.env (gitignored). Shell exports override this file.
# If you still see hive / sqoop_test at runtime, delete configs/sqoop.env and re-copy this file
# (older examples used hive + sqoop_test and break the stock smoke_import setup).
#
# 1) Load data once (as MySQL admin):
#      mysql -u root -p < sql/sqoop-smoke-mysql-setup.sql
# 2) Run import-only smoke (defaults match that SQL):
#      ./sqoop-smoke-test.sh
#
# Override host when MySQL is not on the gateway node:
# SQOOP_MYSQL_HOST=db.example.com

SQOOP_MYSQL_HOST=
SQOOP_MYSQL_PORT=3306
SQOOP_MYSQL_DATABASE=sqoop_smoke
SQOOP_MYSQL_USER=sqoop_smoke
SQOOP_MYSQL_PASSWORD=sqoop_smoke

# Optional full round-trip (export + mysql row count):
# SQOOP_SKIP_EXPORT=0
# SQOOP_MYSQL_VERIFY=1
# SQOOP_EXPORT_TABLE=smoke_export
# SQOOP_TRUNCATE_EXPORT=1

# SQOOP_MYSQL_PASSWORD_FILE=/path/to/password-file
